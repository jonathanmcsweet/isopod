# EditorConfig — https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true

# Shell scripts. These keys are also read by shfmt, so keep them in sync with the
# shfmt args in .pre-commit-config.yaml (-i 2 -ci) — both must produce the same
# formatting whether run via the hook or bare `shfmt`.
[{*.sh,*.bash,isopod}]
indent_style = space
indent_size = 2
switch_case_indent = true
